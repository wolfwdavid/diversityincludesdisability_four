		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.20.0",
		"globals": "^17.7.0",
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "4.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "1.8.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.62.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fontsource/lexend": "5.2.11",
		"@fontsource/source-sans-3": "5.2.9",
